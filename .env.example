# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=your-anon-key

# Necesarias para importación Excel y ETL (conexión directa a Postgres y permisos de servicio).
# SUPABASE_DB_URL: Settings > Database > Connection string > URI (modo "Transaction" o "Session").
# SUPABASE_SERVICE_ROLE_KEY: Settings > API > service_role (secret).
SUPABASE_DB_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Opcional: carpeta con más espacio que el temporal del sistema para descargar Excel (.csv/.xls/.ods).
# Los .xlsx/.xlsm se procesan por streaming y no usan este directorio si la extensión del archivo es correcta.
# IMPORT_TMP_DIR=/Volumes/TuDiscoGrande/tmp_imports

# Vercel / importaciones grandes: URL pública del sitio (para encadenar POST /api/process-excel entre invocaciones).
# NEXT_PUBLIC_SITE_URL=https://tu-app.vercel.app
# Secreto para llamadas internas continuation (misma cadena en header x-internal-process-excel). Recomendado en producción.
# INTERNAL_PROCESS_EXCEL_SECRET=
# Ms máximos por invocación antes de encadenar la siguiente (0 = desactivar chunking). Por defecto 180000.
# PROCESS_EXCEL_CHUNK_MS=180000

# Clave para cifrar contraseñas de conexiones en la base (mín. 32 caracteres). Necesaria para guardar contraseñas desde la plataforma.
ENCRYPTION_KEY=

# Contraseña por defecto para conexiones Firebird si no se guardó en la plataforma (opcional).
# FLEXXUS_PASSWORD=
